      "ruleId": "github.public_repository_created",
      "provider": "GITHUB",
      "state": "go-parity",
      "typescriptEventAliases": ["PUBLIC_REPOSITORY_CREATED"],
      "typescriptPayloadPredicates": [
        "repository.private === false",
        "repository.visibility === public"
      ],
      "goClaimedEventTypes": ["PUBLIC_REPOSITORY_CREATED", "repository.publicized"],
      "fixtures": [
        "tests/fixtures/worker-parity/github-public-repository.json"
      ],
      "tests": [
        "tests/github-rules.test.ts",
        "internal/ingestionworker/worker_test.go",
        "internal/ingestionworker/worker_db_test.go"
      ],
      "cutoverBlockers": [
        "Go validates a connected provider/integration and honors disabled checks, but does not decrypt and integrity-check encrypted integration credentials like the TypeScript reference.",
        "GitHub payload-predicate detection is fixture-tested and the shared publicized event alias is DB-backed, while broader GitHub repository visibility aliases remain TypeScript-reference fallback until individually fixture-backed."
      ],
      "goDefaultBlocked": true
    },
