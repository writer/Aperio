{
  "version": 1,
  "finalCutoverPlan": {
    "status": "ingestion-go-default-enforced",
    "defaultsFlippedInThisFeature": true,
    "fixture": "tests/fixtures/migration-ownership/final-cutover-plan.json",
    "localHarness": "tests/fixtures/worker-parity/foundation-local-harness.json#ingestion",
    "goDefaultRequires": [
      "every rule row is go-default with fixture, unit, DB, smoke, and credential/config evidence",
      "provider credential envelopes pass positive, missing-key, malformed, wrong-AAD, and tampered-tag cases",
      "DB-backed side-effect tests prove no event/finding/SIEM writes on credential or config failure",
      "bounded unsuffixed worker smokes exercise npm run worker:ingestion and make worker-ingestion"
    ]
  },
