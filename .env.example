# Local database
DATABASE_URL="postgresql://aperio:aperio@localhost:5432/aperio?schema=public"

# HTTP origins
APERIO_CONNECT_ADDR=":4100"
APERIO_WEB_ORIGIN="http://localhost:3000"
NEXT_PUBLIC_CONNECT_API_BASE_URL="http://localhost:4100"

# Secrets
# Generate a production value with:
#   node -e "console.log('base64:' + require('node:crypto').randomBytes(32).toString('base64'))"
APERIO_ENCRYPTION_KEY="base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="
APERIO_AUTH_SECRET="replace-me-with-at-least-32-random-characters"

# Sessions
APERIO_SESSION_TTL_HOURS=12
APERIO_SESSION_IDLE_MINUTES=120
APERIO_MFA_ISSUER="Aperio"

# Demo data
DEMO_ORGANIZATION_ID="org_demo_000000000000000000000001"
DEMO_USER_ID="usr_demo_000000000000000000000001"
DEMO_OWNER_PASSWORD="change-me-for-local-demo-only"

# Development-only auth escape hatch. Keep false in shared and production environments.
APERIO_ALLOW_INSECURE_DEMO_AUTH=false
APERIO_EXPOSE_AUTH_LINKS=false
APERIO_ALLOW_PREVIEW_CONNECTORS=false

# Email delivery
APERIO_EMAIL_PROVIDER=""
APERIO_RESEND_API_KEY=""
APERIO_EMAIL_FROM=""

# Google Workspace OAuth
GOOGLE_WORKSPACE_CLIENT_ID=""
GOOGLE_WORKSPACE_CLIENT_SECRET=""
GOOGLE_WORKSPACE_REDIRECT_URI="http://localhost:4100/api/v1/integrations/google-workspace/oauth/callback"

# Google Workspace service-account scans
GOOGLE_WORKSPACE_SERVICE_ACCOUNT_CLIENT_EMAIL=""
GOOGLE_WORKSPACE_SERVICE_ACCOUNT_PRIVATE_KEY=""

# SIEM JSONL exports
APERIO_SIEM_EXPORT_DIR="./generated/siem"

# Event bus
APERIO_EVENT_BUS="noop"
APERIO_NATS_URL="nats://127.0.0.1:4222"
APERIO_NATS_STREAM="CEREBRO_EVENTS"

# Backups and readiness
APERIO_BACKUP_STORAGE_URL=""
APERIO_BACKUP_SCHEDULE=""
APERIO_BACKUP_RETENTION_DAYS=0
